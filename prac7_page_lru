pages = list(map(int, input("Pages: ").split()))
f = int(input("Frames: "))

frame = []
fault = 0

for p in pages:
    if p in frame:
        frame.remove(p)
    else:
        fault += 1
        if len(frame) == f:
            frame.pop(0)
    frame.append(p)

print("Page Faults:", fault)
print("Page Faults Ratio:", fault/len(pages))


